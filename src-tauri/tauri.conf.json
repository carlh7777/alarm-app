{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alarm App",
  "version": "0.1.0",
  "identifier": "com.alarm.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Alarms",
        "width": 480,
        "height": 640,
        "visible": true,
        "resizable": true
      },
      {
        "label": "alert",
        "url": "alert.html",
        "title": "Alarm",
        "width": 400,
        "height": 220,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
